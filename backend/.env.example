# =============================================================================
# OSFLSystem - Variables de Entorno (Ejemplo)
# =============================================================================
# Instrucciones:
# 1. Copia este archivo y renómbralo a .env
# 2. Nunca compartas tu archivo .env real (contiene secretos)
# 3. Este archivo .env.example SÍ debe estar en el repositorio
# =============================================================================

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DEL SERVIDOR
# -----------------------------------------------------------------------------
# Puerto donde correrá el servidor backend
PORT=3000

# Entorno de ejecución (development, production, test)
NODE_ENV=development

# -----------------------------------------------------------------------------
# BASE DE DATOS (MongoDB)
# -----------------------------------------------------------------------------
# URI de conexión a MongoDB
# Formato: mongodb://usuario:password@host:puerto/base_datos
MONGODB_URI=mongodb://localhost:27017/osflsystem_dev

# -----------------------------------------------------------------------------
# SEGURIDAD (JWT - JSON Web Tokens)
# -----------------------------------------------------------------------------
# Secreto para firmar los tokens JWT (debe ser una cadena larga y aleatoria)
# Generar con: openssl rand -base64 32
JWT_SECRET=tu_secreto_jwt_muy_largo_y_seguro_aqui

# Tiempo de expiración del token (ej: 1h, 24h, 7d)
JWT_EXPIRES_IN=24h

# -----------------------------------------------------------------------------
# CLOUDINARY (Almacenamiento de Imágenes)
# -----------------------------------------------------------------------------
# Nombre de tu cuenta en Cloudinary
CLOUDINARY_CLOUD_NAME=tu_cloud_name

# API Key de Cloudinary
CLOUDINARY_API_KEY=tu_api_key

# API Secret de Cloudinary
CLOUDINARY_API_SECRET=tu_api_secret

# Carpeta por defecto para subir imágenes
CLOUDINARY_UPLOAD_FOLDER=osflsystem

# -----------------------------------------------------------------------------
# SERVICIO DE EMAIL (Nodemailer)
# -----------------------------------------------------------------------------
# Host del servidor SMTP
EMAIL_HOST=smtp.gmail.com

# Puerto del servidor SMTP
EMAIL_PORT=587

# Usuario de la cuenta de email
EMAIL_USER=tu_correo@gmail.com

# Password de la cuenta de email (o App Password si usas Gmail)
EMAIL_PASSWORD=tu_password_de_aplicacion

# Email desde el cual se enviarán los correos
EMAIL_FROM=OSFLSystem <no-reply@osflsystem.com>

# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------------------------
# URL del frontend que tendrá acceso a la API
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# RATE LIMITING (Límite de Peticiones)
# -----------------------------------------------------------------------------
# Número máximo de peticiones por ventana de tiempo
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100