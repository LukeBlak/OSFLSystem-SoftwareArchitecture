# -----------------------------------------------------------------------------
# CONFIGURACIÓN DEL SERVIDOR
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# SUPABASE (Base de Datos + Auth + Storage)
# -----------------------------------------------------------------------------
# URL de tu proyecto en Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co

# Anon/Public Key (para operaciones normales)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key (PARA OPERACIONES ADMINISTRATIVAS - MANTENER SECRETO)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# SEGURIDAD (JWT)
# -----------------------------------------------------------------------------
# Generar con: openssl rand -base64 32 (en Linux/Mac)
# O con: https://www.generatesecretkey.com/
JWT_SECRET=tu_secreto_jwt_muy_largo_y_seguro_aqui_cambia_esto
JWT_EXPIRES_IN=1h

# -----------------------------------------------------------------------------
# CLOUDINARY
# -----------------------------------------------------------------------------
# ⚠️ SIN ESPACIOS después del signo =
CLOUDINARY_CLOUD_NAME=dwi1lmdmt
CLOUDINARY_API_KEY=447288961479518
CLOUDINARY_API_SECRET=MXBIQtbg-ripwlESuDoPH15xHgM
CLOUDINARY_UPLOAD_FOLDER=osflsystem

# -----------------------------------------------------------------------------
# SERVICIO DE EMAIL
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_correo@gmail.com
# ⚠️ Usar App Password, no tu password normal de Gmail
# Generar en: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=OSFLSystem <no-reply@osflsystem.com>

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100