# =============================================================================
# OSFLSystem - Variables de Entorno (LOCAL - NO COMPARTIR)
# =============================================================================
# ⚠️  ADVERTENCIA: Este archivo contiene información sensible
# ⚠️  NUNCA subas este archivo a Git o repositorios públicos
# =============================================================================

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DEL SERVIDOR
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# BASE DE DATOS (MongoDB)
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017/osflsystem_dev

# -----------------------------------------------------------------------------
# SEGURIDAD (JWT)
# -----------------------------------------------------------------------------
# ⚠️  CAMBIA ESTO POR UN VALOR SEGURO EN PRODUCCIÓN
JWT_SECRET=OSFLSystem_JWT_Secret_2025_SecureKey_DoNotShare_123456789
JWT_EXPIRES_IN=24h

# -----------------------------------------------------------------------------
# CLOUDINARY
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=osflsystem

# -----------------------------------------------------------------------------
# SERVICIO DE EMAIL
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=OSFLSystem <no-reply@osflsystem.com>

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100